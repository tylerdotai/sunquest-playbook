        "link_2_defeat": {"url": "/the-crypt/crypt-king-defeat/", "samples": 10, "wins": 0, "win_rate": "0%", "note": "Deterministic LOSE"}
      },
      "troll_dungeon": {
        "fight_page": "/troll-dungeon/troll-dungeon-no-bow/",
