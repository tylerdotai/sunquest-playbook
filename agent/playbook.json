        "with_bow": {"url": "/troll-dungeon/troll-dungeon-fight-equip-bow-victory/", "samples": 10, "wins": 10, "win_rate": "100%", "note": "Deterministic WIN with bow"},
        "without_bow": {"note": "Not tested — fight page structure changes based on inventory"}
      },
      "mummy": {
        "fight_page": "/the-crypt/enter-l9-mummy-relic/",
        "mechanism": "none",
        "description": "NOT a combat page. This is a relic reward collection screen. No fight occurs.",
        "outcome": "N/A — reward/collection event"
      },
      "skull_dungeon_714": {
        "fight_page": "/skull-dungeon/714-2/",
