        "description": "Navigation hub only. No combat trigger found.",
        "outcome": "N/A — navigation hub"
      },
      "skull_dungeon_719": {
        "fight_page": "/skull-dungeon/719-2/",
        "mechanism": "none",
        "description": "Navigation hub only. No combat trigger found.",
        "outcome": "N/A — navigation hub"
      },
      "skull_dungeon_729": {
        "fight_page": "/skull-dungeon/729-2/",
        "mechanism": "puzzle",
        "description": "Two puzzle chests (riddle + standard). Solving leads to /skull-dungeon/completed/.",
        "puzzle_1": {"url": "/p-skull-room-lock/", "type": "standard chest"},
        "puzzle_2": {"url": "/p-skull-room-lock-gs/", "type": "riddle", "riddle": "I'm bone, but not alive, Empty sockets where eyes did reside. What am I, that grins and stares, A relic of death that nobody dares?", "answer": "SKULL"}
